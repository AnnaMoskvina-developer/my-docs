2\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u0438 Markdown","text":""},{"location":"advanced-example/#footnotes","title":"\u0421\u043d\u043e\u0441\u043a\u0438","text":"<p>\u0422\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u0430\u0446\u0438\u044f \u0447\u0430\u0441\u0442\u043e \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u043f\u043e\u044f\u0441\u043d\u0435\u043d\u0438\u0439[^1]. \u0421\u043d\u043e\u0441\u043a\u0438 \u043c\u043e\u0436\u043d\u043e \u0434\u043e\u0431\u0430\u0432\u043b\u044f\u0442\u044c \u0432 \u043b\u044e\u0431\u043e\u043c \u043c\u0435\u0441\u0442\u0435[^2].</p> <p>[^1]: \u042d\u0442\u043e \u043f\u0440\u0438\u043c\u0435\u0440 \u0441\u043d\u043e\u0441\u043a\u0438. \u041e\u043d\u0430 \u043f\u043e\u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0432\u043d\u0438\u0437\u0443 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u044b. [^2]: \u0421\u043d\u043e\u0441\u043a\u0438 \u043d\u0443\u043c\u0435\u0440\u0443\u044e\u0442\u0441\u044f \u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438.</p>"},{"location":"advanced-example/#admonitions","title":"\u041f\u0440\u0435\u0434\u0443\u043f\u0440\u0435\u0436\u0434\u0435\u043d\u0438\u044f \u0438 \u0437\u0430\u043c\u0435\u0442\u043a\u0438","text":"<p>\u041f\u0440\u0438\u043c\u0435\u0447\u0430\u043d\u0438\u0435</p> <p>\u042d\u0442\u043e \u043f\u0440\u043e\u0441\u0442\u043e \u0437\u0430\u043c\u0435\u0442\u043a\u0430. \u0414\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u0430\u044f \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044f.</p> <p>\u0412\u043d\u0438\u043c\u0430\u043d\u0438\u0435</p> <p>\u0412\u0430\u0436\u043d\u0430\u044f \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044f, \u0442\u0440\u0435\u0431\u0443\u044e\u0449\u0430\u044f \u0432\u043d\u0438\u043c\u0430\u043d\u0438\u044f.</p> <p>\u041e\u043f\u0430\u0441\u043d\u043e!</p> <p>\u0414\u0435\u0439\u0441\u0442\u0432\u0438\u0435 \u043c\u043e\u0436\u0435\u0442 \u043f\u0440\u0438\u0432\u0435\u0441\u0442\u0438 \u043a \u043f\u043e\u0442\u0435\u0440\u0435 \u0434\u0430\u043d\u043d\u044b\u0445.</p>"},{"location":"advanced-example/#collapsible","title":"\u0421\u0432\u043e\u0440\u0430\u0447\u0438\u0432\u0430\u0435\u043c\u044b\u0435 \u0431\u043b\u043e\u043a\u0438","text":"\u041d\u0430\u0436\u043c\u0438\u0442\u0435, \u0447\u0442\u043e\u0431\u044b \u0443\u0432\u0438\u0434\u0435\u0442\u044c \u043f\u043e\u0434\u0440\u043e\u0431\u043d\u043e\u0441\u0442\u0438  \u0417\u0434\u0435\u0441\u044c \u043c\u043e\u0436\u0435\u0442 \u0431\u044b\u0442\u044c: - \u041b\u044e\u0431\u043e\u0439 \u0442\u0435\u043a\u0441\u0442 - \u0422\u0430\u0431\u043b\u0438\u0446\u044b - \u041a\u043e\u0434  <pre><code>docker run -d -p 80:80 nginx\n</code></pre>"},{"location":"advanced-example/#tasklist","title":"\u0421\u043f\u0438\u0441\u043e\u043a \u0437\u0430\u0434\u0430\u0447","text":"<ul> <li>[x] \u0418\u0437\u0443\u0447\u0438\u0442\u044c \u0431\u0430\u0437\u043e\u0432\u044b\u0439 Markdown</li> <li>[x] \u0421\u043e\u0437\u0434\u0430\u0442\u044c \u0440\u0435\u043f\u043e\u0437\u0438\u0442\u043e\u0440\u0438\u0439 \u043d\u0430 GitHub</li> <li>[x] \u041d\u0430\u0441\u0442\u0440\u043e\u0438\u0442\u044c MkDocs</li> <li>[ ] \u0414\u043e\u0431\u0430\u0432\u0438\u0442\u044c \u043f\u0440\u043e\u0434\u0432\u0438\u043d\u0443\u0442\u044b\u0435 \u044d\u043b\u0435\u043c\u0435\u043d\u0442\u044b</li> <li>[ ] \u041e\u043f\u0443\u0431\u043b\u0438\u043a\u043e\u0432\u0430\u0442\u044c \u043d\u0430 GitHub Pages</li> </ul>"},{"location":"advanced-example/#table","title":"\u0421\u043b\u043e\u0436\u043d\u0430\u044f \u0442\u0430\u0431\u043b\u0438\u0446\u0430","text":"\u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440 \u0422\u0438\u043f \u041e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 \u041f\u0440\u0438\u043c\u0435\u0440 <code>name</code> string \u2705 \u0418\u043c\u044f \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044f <code>\"Anna\"</code> <code>age</code> integer \u274c \u0412\u043e\u0437\u0440\u0430\u0441\u0442 <code>25</code> <code>roles</code> array \u274c \u0421\u043f\u0438\u0441\u043e\u043a \u0440\u043e\u043b\u0435\u0439 <code>[\"admin\", \"user\"]</code>"},{"location":"advanced-example/#code","title":"\u041a\u043e\u0434 \u0441 \u043f\u043e\u044f\u0441\u043d\u0435\u043d\u0438\u044f\u043c\u0438","text":"<pre><code>def process_data(data):\n    \"\"\"\u041e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0430 \u0434\u0430\u043d\u043d\u044b\u0445\"\"\"\n    if not data:  # \u041f\u0440\u043e\u0432\u0435\u0440\u043a\u0430 \u043d\u0430 \u043f\u0443\u0441\u0442\u044b\u0435 \u0434\u0430\u043d\u043d\u044b\u0435\n        return []\n\n    result = [item for item in data if item.is_valid()]\n    return result\n</code></pre>"},{"location":"advanced-example/#links","title":"\u0421\u0441\u044b\u043b\u043a\u0438 \u043d\u0430 \u0437\u0430\u0433\u043e\u043b\u043e\u0432\u043a\u0438","text":"<p>\u041f\u0435\u0440\u0435\u0439\u0442\u0438 \u043a \u0440\u0430\u0437\u0434\u0435\u043b\u0443 \u043e \u0441\u043d\u043e\u0441\u043a\u0430\u0445 \u0438\u043b\u0438 \u043a \u0442\u0430\u0431\u043b\u0438\u0446\u0435.</p>"},{"location":"advanced-example/#image","title":"\u0418\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435","text":"<p>\u0412\u043e\u0442 \u043f\u0440\u0438\u043c\u0435\u0440 \u0442\u043e\u0433\u043e, \u043a\u0430\u043a \u0432\u0441\u0442\u0430\u0432\u043b\u044f\u0442\u044c \u0438\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u044f \u0432 \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u0430\u0446\u0438\u044e:</p> <p></p> <p>\u0420\u0438\u0441\u0443\u043d\u043e\u043a 1 \u2014 \u041f\u0440\u0438\u043c\u0435\u0440 \u043e\u0444\u043e\u0440\u043c\u043b\u0435\u043d\u0438\u044f \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u0430\u0446\u0438\u0438 (\u0448\u0438\u0440\u0438\u043d\u0430 400px)</p>"}]}